# Python (Vercel Environment Variables + local .env)
EDGAR_IDENTITY="Your Name your-email@example.com"
# Default when the UI does not send a model (server fallback)
LITELLM_MODEL="openai/gpt-4"
OPENAI_API_KEY=""
# Optional — needed when selecting Anthropic / Google in the app (LiteLLM)
# ANTHROPIC_API_KEY=""
# GEMINI_API_KEY=""

# Optional: override API origin (default: same-origin, e.g. empty on Vercel)
# NEXT_PUBLIC_API_BASE_URL=

# Chat: server default system prompt (optional). UI override requires COPILOT_ALLOW_CLIENT_SYSTEM_PROMPT=1.
# COPILOT_SYSTEM_PROMPT="You are SEC Copilot..."
# COPILOT_ALLOW_CLIENT_SYSTEM_PROMPT=1

# Chat: optional bounds for per-request slider limits (defaults shown in llm_service.py)
# COPILOT_CURRENT_CONTEXT_CHARS_MIN=2000
# COPILOT_CURRENT_CONTEXT_CHARS_MAX=120000
# COPILOT_ADDITIONAL_CONTEXT_CHARS_MIN=0
# COPILOT_ADDITIONAL_CONTEXT_CHARS_MAX=80000
